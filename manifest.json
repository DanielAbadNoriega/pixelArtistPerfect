{
  "manifest_version": 3,
  "name": "PixelFromen Studio",
  "version": "1.1.0",
  "description": "Pixel-perfect layout guides for any page",
  "action": {
    "default_icon": {
      "16": "images/16.png",
      "24": "images/24.png",
      "32": "images/32.png"
    },
    "default_popup": "interface.html",
    "default_title": "PixelFromen Studio"
  },
  "icons": {
    "16": "images/16.png",
    "24": "images/24.png",
    "32": "images/32.png",
    "48": "images/48.png",
    "64": "images/64.png",
    "128": "images/128.png"
  },
  "background": {
    "service_worker": "scripts/pixel-studio.background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "scripts/jquery-1.10.2.min.js",
        "scripts/pixel-studio.content.js"
      ],
      "css": ["styles/pixel-studio.content.css"]
    }
  ],
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "commands": {
    "add-horizontal-guide": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Alt+Shift+H"
      },
      "description": "Create a horizontal guide"
    },
    "add-vertical-guide": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Alt+Shift+V"
      },
      "description": "Create a vertical guide"
    },
    "toggle-settings-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "windows": "Ctrl+Shift+Y",
        "mac": "Alt+Shift+P"
      },
      "description": "Toggle the floating settings panel"
    },
    "clear-all-guides": {
      "suggested_key": {
        "default": "Alt+Shift+X",
        "mac": "Option+Shift+X"
      },
      "description": "Clear every guide on the current page"
    },
    "clear-vertical-guides": {
      "description": "Clear all vertical guides on the current page"
    },
    "clear-horizontal-guides": {
      "description": "Clear all horizontal guides on the current page"
    },
    "toggle-delete-mode": {
      "description": "Toggle delete mode to remove one guide"
    }
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
