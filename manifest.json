{
   "background": {
      "scripts": [ "scripts/guideLinr.background.js" ]
   },
   "browser_action": {
      "default_icon": "images/16.png",
      "default_popup": "interface.html",
      "default_title": "guideLinr",
      "permissions": [ "tabs", "http://*/*", "https://*/*" ]
   },
   "content_scripts": [ {
      "css": [ "styles/guideLinr.inject.css" ],
      "js": [ "scripts/jquery-1.10.2.min.js", "scripts/guideLinr.inject.js" ],
      "matches": [ "http://*/*", "https://*/*" ]
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
   "description": "Photoshop-like guide lines for any page",
   "icons": {
      "128": "images/128.png",
      "16": "images/16.png",
      "24": "images/24.png",
      "32": "images/32.png",
      "48": "images/48.png",
      "64": "images/64.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "guideLinr",
   "permissions": [ "tabs", "contextMenus", "http://*/*", "https://*/*", "*://*/*" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1.0"
}
