{
  "manifest_version": 3,
  "name": "PixelFromen Studio",
  "version": "1.1.0",
  "description": "Pixel-perfect layout guides for any page",
  "action": {
    "default_icon": "images/16.png",
    "default_popup": "interface.html",
    "default_title": "PixelFromen Studio"
  },
  "icons": {
    "16": "images/16.png",
    "24": "images/24.png",
    "32": "images/32.png",
    "48": "images/48.png",
    "64": "images/64.png",
    "128": "images/128.png"
  },
  "background": {
    "service_worker": "scripts/guideLinr.background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "scripts/jquery-1.10.2.min.js",
        "scripts/guideLinr.inject.js"
      ],
      "css": ["styles/guideLinr.inject.css"]
    }
  ],
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
